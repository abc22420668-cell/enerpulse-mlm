# Django
DJANGO_SECRET_KEY=replace-with-a-real-secret-key
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=.onrender.com,localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=https://*.onrender.com,http://localhost:8000,http://127.0.0.1:8000

# Database (SQLite on Render - no PostgreSQL free tier)
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=enerpulse
# DB_USER=enerpulse
# DB_PASSWORD=your_password
# DB_HOST=your-db-host
# DB_PORT=5432

# Redis (optional on Render - Celery will be disabled fallback)
# REDIS_URL=redis://localhost:6379/0

# Superuser (auto-created on first deploy)
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@enerpulse.com
DJANGO_SUPERUSER_PASSWORD=admin123

# Site
SITE_URL=https://enerpulse-mlm.onrender.com
SITE_NAME=EnerPulse MLM Platform
